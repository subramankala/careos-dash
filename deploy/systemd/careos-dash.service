[Unit]
Description=Ginger Care-Dash (Caregiver Dashboard Surface)
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/kumarmankala/careos-dash
EnvironmentFile=/home/kumarmankala/careos-dash/.env
ExecStart=/home/kumarmankala/careos-dash/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3
User=kumarmankala
Group=kumarmankala

[Install]
WantedBy=multi-user.target
